<% layout('layouts/boilerplate') %>

<div class="d-flex justify-content-center align-items-center" style="min-height:90vh;">

<div class="card shadow-lg border-0 p-4" style="width:500px;">

<h3 class="text-center mb-4">Add New Product</h3>

<form action="/products" method="POST">

<div class="mb-3">
<label class="form-label">Product Name</label>
<input class="form-control" name="product[name]" placeholder="Enter product name" required>
</div>

<div class="mb-3">
<label class="form-label">SKU</label>
<input class="form-control" name="product[sku]" placeholder="Stock Keeping Unit" required>
</div>

<div class="row">
<div class="col-md-6 mb-3">
<label class="form-label">Quantity</label>
<input class="form-control" name="product[quantity]" type="number" placeholder="0">
</div>

<div class="col-md-6 mb-3">
<label class="form-label">Low Stock Threshold</label>
<input class="form-control" name="product[lowStockThreshold]" type="number" placeholder="5">
</div>
</div>

<div class="row">
<div class="col-md-6 mb-3">
<label class="form-label">Cost Price</label>
<input class="form-control" name="product[costPrice]" type="number" placeholder="₹0">
</div>

<div class="col-md-6 mb-3">
<label class="form-label">Selling Price</label>
<input class="form-control" name="product[sellingPrice]" type="number" placeholder="₹0">
</div>
</div>

<div class="mb-3">
<label class="form-label">Description</label>
<textarea class="form-control" name="product[description]" rows="3" placeholder="Optional product description"></textarea>
</div>

<div class="d-flex justify-content-between">

<a href="/products" class="btn btn-outline-secondary">
Back
</a>

<button class="btn btn-success">
Create Product
</button>

</div>

</form>

</div>

</div>