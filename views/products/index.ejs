<% layout('layouts/boilerplate') %>

<div class="container mt-4">

<div class="d-flex justify-content-between align-items-center mb-4">
<h3 class="mb-0">Product Inventory</h3>

<a href="/products/new" class="btn btn-primary">
+ Add Product
</a>
</div>


<div class="card shadow-sm border-0">

<div class="card-body">

<table class="table table-hover align-middle">

<thead class="table-light">
<tr>
<th>Product</th>
<th>SKU</th>
<th>Quantity</th>
<th>Selling Price</th>
<th class="text-center">Actions</th>
</tr>
</thead>

<tbody>

<% if(products.length === 0){ %>

<tr>
<td colspan="5" class="text-center text-muted py-4">
No products found. Add your first product.
</td>
</tr>

<% } %>

<% products.forEach(product => { %>

<tr>

<td>
<strong><%= product.name %></strong>
</td>

<td>
<span class="text-muted"><%= product.sku %></span>
</td>

<td>

<% if(product.quantity <= product.lowStockThreshold){ %>

<span class="badge bg-danger">
Low (<%= product.quantity %>)
</span>

<% } else { %>

<span class="badge bg-success">
<%= product.quantity %>
</span>

<% } %>

</td>

<td>
₹ <%= product.sellingPrice %>
</td>

<td class="text-center">

<a href="/products/<%= product._id %>/edit"
class="btn btn-outline-warning btn-sm me-2">
Edit
</a>

<form action="/products/<%= product._id %>/delete"
method="POST"
style="display:inline">

<button class="btn btn-outline-danger btn-sm">
Delete
</button>

</form>

</td>

</tr>

<% }) %>

</tbody>

</table>

</div>

</div>

</div>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<% if(success === "productCreated"){ %>
<script>
Swal.fire({
icon: "success",
title: "Product Added",
text: "Product created successfully!"
});
</script>
<% } %>

<% if(success === "productUpdated"){ %>
<script>
Swal.fire({
icon: "success",
title: "Product Updated",
text: "Product updated successfully!"
});
</script>
<% } %>

<% if(success === "productDeleted"){ %>
<script>
Swal.fire({
icon: "success",
title: "Product Deleted",
text: "Product removed successfully!"
});
</script>
<% } %>

<% if(error === "productCreateFailed"){ %>
<script>
Swal.fire({
icon: "error",
title: "Error",
text: "Failed to create product"
});
</script>
<% } %>

<% if(error === "productUpdateFailed"){ %>
<script>
Swal.fire({
icon: "error",
title: "Error",
text: "Failed to update product"
});
</script>
<% } %>

<% if(error === "productDeleteFailed"){ %>
<script>
Swal.fire({
icon: "error",
title: "Error",
text: "Failed to delete product"
});
</script>
<% } %>