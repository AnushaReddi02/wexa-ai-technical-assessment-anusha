<% layout('layouts/boilerplate') %>

<style>

.dashboard-card{
transition:all 0.3s ease;
border-radius:16px;
}

.dashboard-card:hover{
transform:translateY(-6px);
box-shadow:0 12px 28px rgba(0,0,0,0.18);
cursor:pointer;
}

.stat-icon{
width:70px;
height:70px;
border-radius:50%;
display:flex;
align-items:center;
justify-content:center;
font-size:28px;
color:white;
}

.gradient-blue{
background:linear-gradient(135deg,#3b82f6,#6366f1);
}

.gradient-green{
background:linear-gradient(135deg,#22c55e,#16a34a);
}

.table-hover tbody tr:hover{
background:#f1f5ff;
transition:0.2s;
}

/* Chart cards */

.chart-card{
height:380px;
display:flex;
flex-direction:column;
}

.chart-card .card-body{
flex:1;
display:flex;
align-items:center;
justify-content:center;
}

.chart-card canvas{
max-height:260px;
width:100% !important;
}

</style>


<div class="container mt-4">

<h3 class="fw-bold mb-4">Inventory Dashboard</h3>


<!-- Stat Cards -->

<div class="row g-4 mb-4">

<div class="col-md-6">

<div class="card dashboard-card border-0 shadow">

<div class="card-body d-flex justify-content-between align-items-center">

<div>
<h6 class="text-muted">Total Products</h6>
<h2 class="fw-bold text-primary counter" data-target="<%= totalProducts %>">0</h2>
</div>

<div class="stat-icon gradient-blue">
<i class="bi bi-box-seam"></i>
</div>

</div>

</div>

</div>


<div class="col-md-6">

<div class="card dashboard-card border-0 shadow">

<div class="card-body d-flex justify-content-between align-items-center">

<div>
<h6 class="text-muted">Total Inventory Quantity</h6>
<h2 class="fw-bold text-success counter" data-target="<%= totalQuantity %>">0</h2>
</div>

<div class="stat-icon gradient-green">
<i class="bi bi-archive"></i>
</div>

</div>

</div>

</div>

</div>


<!-- Charts -->

<div class="row g-4 mb-4">

<div class="col-md-6">

<div class="card border-0 shadow dashboard-card chart-card">

<div class="card-header bg-white fw-semibold">
Inventory Health
</div>

<div class="card-body">
<canvas id="healthChart"></canvas>
</div>

</div>

</div>


<div class="col-md-6">

<div class="card border-0 shadow dashboard-card chart-card">

<div class="card-header bg-white fw-semibold">
Product Quantity Distribution
</div>

<div class="card-body">
<canvas id="productChart"></canvas>
</div>

</div>

</div>

</div>


<!-- Low Stock Table -->

<div class="card border-0 shadow dashboard-card">

<div class="card-header bg-white fw-semibold">
Low Stock Products
</div>

<div class="card-body">

<table class="table table-hover align-middle">

<thead class="table-light">

<tr>
<th>Product</th>
<th>SKU</th>
<th>Quantity</th>
<th>Threshold</th>
<th>Status</th>
</tr>

</thead>

<tbody>

<% if(lowStockProducts.length === 0){ %>

<tr>
<td colspan="5" class="text-center text-muted py-4">
All inventory levels are healthy
</td>
</tr>

<% } %>


<% lowStockProducts.forEach(product => { %>

<tr>

<td class="fw-semibold"><%= product.name %></td>

<td class="text-muted"><%= product.sku %></td>

<td>
<span class="badge bg-danger px-3 py-2">
<%= product.quantity %>
</span>
</td>

<td><%= product.lowStockThreshold %></td>

<td>
<span class="badge bg-warning text-dark px-3 py-2">
Critical
</span>
</td>

</tr>

<% }) %>

</tbody>

</table>

</div>

</div>

</div>



<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>

const products = <%- JSON.stringify(products) %>;

const lowStockCount = products.filter(p =>
p.quantity <= (p.lowStockThreshold || 5)
).length;

const healthyStock = products.length - lowStockCount;


// Donut Chart

new Chart(document.getElementById('healthChart'),{

type:'doughnut',

data:{
labels:['Healthy Stock','Low Stock'],

datasets:[{
data:[healthyStock,lowStockCount],

backgroundColor:[
'#22c55e',
'#ef4444'
]

}]
},

options:{
responsive:true,
maintainAspectRatio:false,
plugins:{
legend:{
position:'bottom'
}
}
}

});



// Bar Chart

const productNames = products.map(p=>p.name);

const quantities = products.map(p=>p.quantity);


new Chart(document.getElementById('productChart'),{

type:'bar',

data:{
labels:productNames,

datasets:[{
label:'Quantity',
data:quantities,
backgroundColor:'#3b82f6'
}]
},

options:{
responsive:true,
maintainAspectRatio:false,
plugins:{
legend:{
display:false
}
}
}

});



/* Animated Counters */

const counters = document.querySelectorAll('.counter');

counters.forEach(counter => {

const target = +counter.getAttribute('data-target');

let count = 0;

const update = () => {

const increment = target / 60;

if(count < target){

count += increment;

counter.innerText = Math.ceil(count);

setTimeout(update,20);

}else{

counter.innerText = target;

}

};

update();

});

</script>